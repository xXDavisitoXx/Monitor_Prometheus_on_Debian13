name: Update README Download Link

on:
  push:
    paths:
      - '.version' # Triggers ONLY when the .version file is modified by the builder bot
  workflow_dispatch: # Allows manual trigger if needed

jobs:
  patch-readme:
    runs-on: ubuntu-latest
    permissions:
      contents: write # Required to push changes back to the README.md

    steps:
      - name: Checkout repository
        uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2

      - name: Inject version into README markdown link
        run: |
          set -e

          # 1. Read the fresh version generated by the builder bot
          if [ ! -f .version ]; then
            echo "❌ Error: .version file not found. Exiting."
            exit 1
          fi
          
          CURRENT_VERSION=$(cat .version)
          echo "🚀 Synchronizing README with newly released version: v${CURRENT_VERSION}"

          # 2. Regex patch: find 'prometheus_*_amd64.deb' and replace it with the current version
          sed -i -E "s/prometheus_[0-9]+\.[0-9]+\.[0-9]+_amd64\.deb/prometheus_${CURRENT_VERSION}_amd64\.deb/g" README.md

          # 3. Commit and push the updated README safely
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          
          # Check if README actually changed to avoid empty commit errors
          if git diff --quiet README.md; then
            echo "✅ README link is already matching v${CURRENT_VERSION}. No changes needed."
          else
            echo "📝 README link updated. Pushing changes..."
            git add README.md
            git commit -m "docs: auto-update download link to v${CURRENT_VERSION} [skip ci]"
            git push origin main
          fi
